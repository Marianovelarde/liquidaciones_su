generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  GENERADOR
  COBRADOR
}

enum LiquidationStatus {
  PENDIENTE_DE_PAGO
  EN_REVISION
  PAGADO
  OBSERVADO
  ANULADO
}

//////////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////////

model Category {
  id          Int    @id @default(autoincrement())
  name        String @unique
  coefficient Float
  pricePerM2  Float

  deletedAt DateTime?

  liquidations Liquidation[]
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id       Int      @id @default(autoincrement())
  username String   @unique
  password String
  role     UserRole @default(GENERADOR)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  //////////////////////////////////////////////////////
  // Relaciones
  //////////////////////////////////////////////////////

  liquidationsCreated Liquidation[] @relation("CreatedBy")
  auditLogs           AuditLog[]
}

//////////////////////////////////////////////////////
// LIQUIDATION
//////////////////////////////////////////////////////

model Liquidation {
  id Int @id @default(autoincrement())

  //////////////////////////////////////////
  // Número de liquidación
  //////////////////////////////////////////

  emissionNumber Int @unique

  //////////////////////////////////////////
  // Expediente
  //////////////////////////////////////////

  expedienteNumero Int
  expedienteCodigo Int
  expedienteAnio   Int

  //////////////////////////////////////////
  // Carpeta
  //////////////////////////////////////////

  carpetaNumero String
  carpetaLetra  String
  carpetaAnio   String

  //////////////////////////////////////////
  // Padrón
  //////////////////////////////////////////

  distrito Int
  zona     Int
  manzana  Int
  parcela  String

  //////////////////////////////////////////
  // Datos de obra
  //////////////////////////////////////////

  propietario String
  ubicacion   String
  tipoObra    String
  concepto    String

  superficie Float

  //////////////////////////////////////////
  // Categoría
  //////////////////////////////////////////

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  //////////////////////////////////////////
  // Usuario creador
  //////////////////////////////////////////

  createdById Int
  createdBy   User @relation("CreatedBy", fields: [createdById], references: [id])

  //////////////////////////////////////////
  // Recargo
  //////////////////////////////////////////

  hasSurcharge     Boolean @default(false)
  surchargePercent Float?

  //////////////////////////////////////////
  // Observaciones
  //////////////////////////////////////////

  observations String?

  receiptNumber String?

  //////////////////////////////////////////
  // Total
  //////////////////////////////////////////

  total Float

  //////////////////////////////////////////
  // Estado
  //////////////////////////////////////////

  status LiquidationStatus @default(PENDIENTE_DE_PAGO)

  //////////////////////////////////////////
  // Auditoría
  //////////////////////////////////////////

  auditLogs AuditLog[]

  //////////////////////////////////////////
  // Fechas
  //////////////////////////////////////////

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id Int @id @default(autoincrement())

  //////////////////////////////////////////
  // Usuario que realizó acción
  //////////////////////////////////////////

  userId Int

  user User @relation(fields: [userId], references: [id])

  userRole UserRole

  //////////////////////////////////////////
  // Liquidación afectada
  //////////////////////////////////////////

  liquidationId Int?

  liquidation Liquidation? @relation(fields: [liquidationId], references: [id], onDelete: SetNull)

  //////////////////////////////////////////
  // Acción realizada
  //////////////////////////////////////////

  action AuditAction

  //////////////////////////////////////////
  // Campo afectado
  //////////////////////////////////////////

  field String?

  //////////////////////////////////////////
  // Valores
  //////////////////////////////////////////

  oldValue String?

  newValue String?

  //////////////////////////////////////////
  // Información adicional
  //////////////////////////////////////////

  ipAddress String?

  //////////////////////////////////////////
  // Fecha
  //////////////////////////////////////////

  createdAt DateTime @default(now())
}
